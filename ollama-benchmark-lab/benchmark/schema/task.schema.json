{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SWE-Bench Task Schema v3 (Strict Execution + Replay Compatible)",
  "type": "object",

  "required": [
    "id",
    "mode",
    "public_prompt",
    "version",
    "tests",
    "execution"
  ],

  "properties": {
    "id": {
      "type": "string",
      "description": "Unique task identifier"
    },

    "mode": {
      "type": "string",
      "enum": ["ACT", "PLAN", "SWE"],
      "description": "Task execution mode"
    },

    "public_prompt": {
      "type": "string",
      "description": "User-visible prompt used by the evaluator"
    },

    "version": {
      "type": "string",
      "description": "Task schema version for reproducibility"
    },

    "tests": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "description": "Filesystem path to hidden pytest suite (Docker-mounted or repo-relative)"
        }
      },
      "additionalProperties": false
    },

    "execution": {
      "type": "object",
      "required": ["entrypoint"],
      "properties": {
        "entrypoint": {
          "type": "string",
          "description": "Command executed inside sandbox (e.g. pytest -q, python -m module, etc.)"
        }
      },
      "additionalProperties": false
    },

    "constraints": {
      "type": "object",
      "description": "Optional runtime constraints (timeouts, memory limits, sandbox flags)",
      "additionalProperties": true
    },

    "rubric": {
      "type": "object",
      "description": "Scoring weights used by evaluator",
      "properties": {
        "correctness": { "type": "number" },
        "structure": { "type": "number" },
        "edge_cases": { "type": "number" },
        "efficiency": { "type": "number" }
      },
      "additionalProperties": false
    }
  }
}