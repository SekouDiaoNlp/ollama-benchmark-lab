{
  "project": "ollama-benchmark-lab",

  "model_selection": {
    "mode": "noyap_only",
    "include_patterns": ["-noyap"],
    "exclude_patterns": [],
    "explicit_models": [],
    "fallback_mode": "all_if_empty",
    "validate_models_exist": true
  },

  "execution": {
    "timeout_seconds": 180,
    "max_retries": 2,
    "retry_backoff_seconds": 5,
    "parallel_models": 1,
    "resume_on_failure": true,
    "resume_granularity": "task_level"
  },

  "prompting": {
    "plan_ratio": 0.5,
    "act_ratio": 0.5,
    "shuffle_prompts": true,
    "seed": 42,
    "normalize_whitespace": true
  },

  "checkpointing": {
    "enabled": true,
    "checkpoint_dir": "results",
    "state_file": "results/state.jsonl",
    "heartbeat_file": "results/heartbeat.txt",
    "atomic_writes": true,
    "flush_every_task": true
  },

  "scoring": {
    "enabled": true,
    "metrics": [
      "length",
      "latency",
      "consistency_proxy",
      "structural_validity"
    ],
    "normalize_scores": true,
    "aggregate": "mean"
  },

  "analysis": {
    "enable_failure_taxonomy": true,
    "categories": [
      "syntax_error",
      "type_error",
      "logical_error",
      "api_misuse",
      "hallucination",
      "partial_solution"
    ],
    "enable_bootstrap_confidence": true
  },

  "safety": {
    "auto_repair": true,
    "fail_fast": false,
    "repair_actions": [
      "create_missing_directories",
      "warn_and_continue",
      "log_repair_events"
    ]
  },

  "system_health": {
    "watchdog_enabled": true,
    "heartbeat_interval_seconds": 10,
    "hung_task_threshold_seconds": 300,
    "auto_resume_on_restart": true
  },

  "reporting": {
    "output_dir": "results",
    "formats": ["jsonl", "csv", "md"],
    "live_dashboard": false
  }
}